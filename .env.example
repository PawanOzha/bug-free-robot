## AnyWhere signaling-server (example)
## Copy to `.env` locally or set these in Railway.

# Server
PORT=8085
# Set to true in ALL production deployments (required for WSS)
ENFORCE_TLS=true

# Ingest auth (server-minted token for client HTTP ingest)
# Set these in production (Railway). Never commit real secrets.
INGEST_TOKEN_SECRET=REPLACE_ME_LONG_RANDOM
INGEST_TOKEN_TTL_MS=900000
# Optional: if set, enables ephemeral TURN credentials (recommended for production)
# Must match the static-auth-secret configured in coturn
TURN_SECRET=your_shared_secret_here

# Optional: allow unauthenticated ingest in local-dev only (NOT for production)
# ALLOW_CALL_EVENTS_WITHOUT_TOKEN=false

# Optional DB path for local SQLite (current implementation)
# DB_PATH=./signaling.db

# Supabase / Postgres (set real values only in Railway or local `.env` — never commit secrets)
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true
# Use SSL for production poolers when required:
# SUPABASE_REQUIRE_SSL=true
# PGSSLMODE=require

# Optional Postgres tuning
# PG_CONNECT_TIMEOUT_MS=10000
# PG_POOL_MAX=10
# PG_IDLE_TIMEOUT_MS=30000

# Optional: lock down allowed browser origins (comma-separated). Empty = allow all.
# ALLOWED_ORIGINS=http://localhost:5173,https://your-admin-host.example

# Cloudflare Realtime TURN — server-side only, never sent to clients
# Get from: dash.cloudflare.com → Realtime → TURN → your key. See CLOUDFLARE_SETUP.md in repo root.
CLOUDFLARE_TURN_KEY_ID=paste_your_turn_key_id_here
CLOUDFLARE_TURN_KEY_API_TOKEN=paste_your_api_token_here

# Optional: proxy audit-dashboard super-admin API for Electron (admin-audit-org-access-* WS messages).
# Same AUDIT_SUPERADMIN_SERVICE_SECRET as on the audit-dashboard deployment. URL needs a host;
# scheme optional (http:// added automatically if missing).
# AUDIT_DASHBOARD_URL=http://localhost:3000
# AUDIT_SUPERADMIN_SERVICE_SECRET=REPLACE_ME_LONG_RANDOM
